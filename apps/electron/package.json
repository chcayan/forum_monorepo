{
  "name": "@forum-monorepo/electron",
  "version": "1.1.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "description": "forum built by electron",
  "author": "chcaya",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.0"
  },
  "build": {
    "appId": "org.chcaya.forum",
    "productName": "forum",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": ".env.production",
        "to": ".env.production"
      }
    ]
  }
}
